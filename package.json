{
  "name": "noc-visor",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "homepage": "https://isaacm10.github.io/noc-visor",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "electron": "electron .",
    "electron:build": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.multicable.nocvisor",
    "productName": "NOC Visor",
    "asar": true,
    "win": {
      "target": "portable",
      "icon": "public/icon.ico"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "electron-main.cjs",
      "electron-preload.cjs"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-updater": "^6.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.0.0",
    "vite": "^8.0.9"
  }
}
